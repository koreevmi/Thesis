<Window x:Class="ConstructionMaterialsManager.Views.Windows.QualityCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проверка качества" WindowStartupLocation="CenterScreen"
        Height="560" Width="540" ResizeMode="CanResize" MinHeight="520" MinWidth="500"
        Background="{StaticResource BackgroundBrush}">

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="16" Margin="20"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Проверка качества"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Материал" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="MaterialComboBox" Style="{StaticResource ModernComboBox}"
                          DisplayMemberPath="Name" SelectedValuePath="MaterialId" Height="40" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Номер партии" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="BatchNumberTextBox" Style="{StaticResource ModernTextBox}"
                         Height="40" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата проверки" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <DatePicker Grid.Row="3" Grid.Column="1" x:Name="CheckDatePicker" Style="{StaticResource ModernDatePicker}"
                            Height="40" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Статус" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="StatusComboBox" Style="{StaticResource ModernComboBox}"
                          Height="40" Margin="0,0,0,12">
                    <ComboBoxItem Content="На проверке"/>
                    <ComboBoxItem Content="Одобрено"/>
                    <ComboBoxItem Content="Бракован"/>
                </ComboBox>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Инспектор" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="InspectorTextBox" Style="{StaticResource ModernTextBox}"
                         Height="40" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Результаты" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="6" Grid.Column="1" x:Name="TestResultsTextBox" Style="{StaticResource ModernTextBox}"
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Комментарий" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="7" Grid.Column="1" x:Name="CommentsTextBox" Style="{StaticResource ModernTextBox}"
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20"/>

                <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelBtn" Content="Отмена" Style="{StaticResource SecondaryButton}"
                            Click="CancelBtn_Click" Width="120" Margin="0,0,12,0"/>
                    <Button x:Name="SaveBtn" Content="Сохранить" Style="{StaticResource PrimaryButton}"
                            Click="SaveBtn_Click" Width="140"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
