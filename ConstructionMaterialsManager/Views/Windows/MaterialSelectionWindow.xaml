<Window x:Class="ConstructionMaterialsManager.Views.Windows.MaterialSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор материала" WindowStartupLocation="CenterScreen"
        Height="600" Width="740" ResizeMode="CanResize" MinHeight="540" MinWidth="680"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Добавить материал в проект" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Выберите материал и укажите количество" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0" Margin="0,0,0,16">
            <DataGrid x:Name="MaterialsDataGrid" Style="{StaticResource ModernDataGrid}"
                      AutoGenerateColumns="False">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernDataGridColumnHeader}"/>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}"/>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCell}"/>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding MaterialType.Name}" Width="*"/>
                    <DataGridTextColumn Header="Ед. изм." Binding="{Binding Unit}" Width="Auto"/>
                    <DataGridTextColumn Header="Стоимость" Binding="{Binding CostPerUnit, StringFormat={}{0:N2} ₽}" Width="Auto"/>
                    <DataGridTextColumn Header="Остаток" Binding="{Binding CurrentStock, StringFormat={}{0:N2}}" Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Планируемое количество:" VerticalAlignment="Center"
                       FontSize="13" FontWeight="Medium"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,12,0"/>
            <TextBox x:Name="QuantityTextBox" Style="{StaticResource ModernTextBox}"
                     Width="180" Height="40"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Отмена" Style="{StaticResource SecondaryButton}"
                    Click="CancelButton_Click" Width="120" Margin="0,0,12,0"/>
            <Button x:Name="AddButton" Content="Добавить" Style="{StaticResource PrimaryButton}"
                    Click="AddButton_Click" Width="140"/>
        </StackPanel>
    </Grid>
</Window>
