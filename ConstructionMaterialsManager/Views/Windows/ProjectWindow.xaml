<Window x:Class="ConstructionMaterialsManager.Views.Windows.ProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проект" WindowStartupLocation="CenterScreen"
        Height="600" Width="700" ResizeMode="CanResize" MinHeight="560" MinWidth="640"
        Background="{StaticResource BackgroundBrush}">

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="16" Margin="20"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Проект"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Название" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="ProjectNameTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Описание" Style="{StaticResource FormTextBlock}" VerticalAlignment="Top" Margin="0,10,0,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="ProjectDescriptionTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"
                         Height="70" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата начала" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <DatePicker Grid.Row="3" Grid.Column="1" x:Name="ProjectStartDatePicker" Style="{StaticResource ModernDatePicker}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата окончания" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <DatePicker Grid.Row="4" Grid.Column="1" x:Name="ProjectEndDatePicker" Style="{StaticResource ModernDatePicker}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Бюджет" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="ProjectBudgetTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Статус" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <ComboBox Grid.Row="6" Grid.Column="1" x:Name="ProjectStatusComboBox" Style="{StaticResource ModernComboBox}" Margin="0,0,0,24" Height="40">
                    <ComboBoxItem Content="Запланирован"/>
                    <ComboBoxItem Content="В процессе"/>
                    <ComboBoxItem Content="Завершен"/>
                    <ComboBoxItem Content="Отменен"/>
                </ComboBox>

                <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Отмена" Style="{StaticResource SecondaryButton}"
                            Click="CancelButton_Click" Width="120" Margin="0,0,12,0"/>
                    <Button x:Name="SaveButton" Content="Сохранить" Style="{StaticResource PrimaryButton}"
                            Click="SaveButton_Click" Width="140"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
