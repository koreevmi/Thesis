<Window x:Class="ConstructionMaterialsManager.Views.Windows.SupplierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Поставщик" WindowStartupLocation="CenterScreen"
        Height="560" Width="560" ResizeMode="CanResize" MinHeight="520" MinWidth="520"
        Background="{StaticResource BackgroundBrush}">

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="16" Margin="20"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Поставщик"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Название" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="NameTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Контактное лицо" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="ContactPersonTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Телефон" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="PhoneTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Email" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="EmailTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Адрес" Style="{StaticResource FormTextBlock}" VerticalAlignment="Top" Margin="0,10,0,0"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="AddressTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,24"
                         Height="70" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"/>

                <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelBtn" Content="Отмена" Style="{StaticResource SecondaryButton}"
                            Click="CancelBtn_Click" Width="120" Margin="0,0,12,0"/>
                    <Button x:Name="SaveBtn" Content="Сохранить" Style="{StaticResource PrimaryButton}"
                            Click="SaveBtn_Click" Width="140"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
