<Window x:Class="ConstructionMaterialsManager.Views.Windows.EditProjectMaterialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование материала" WindowStartupLocation="CenterScreen"
        Height="440" Width="500" ResizeMode="CanResize" MinHeight="400" MinWidth="460"
        Background="{StaticResource BackgroundBrush}">

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="16" Margin="20"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Редактирование"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Материал" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="MaterialNameTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Height="40"
                         IsReadOnly="True" Background="#F8FAFC"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Планируемое кол-во" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="PlannedQuantityTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Использовано" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="UsedQuantityTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,24" Height="40"/>

                <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelBtn" Content="Отмена" Style="{StaticResource SecondaryButton}"
                            Click="CancelBtn_Click" Width="120" Margin="0,0,12,0"/>
                    <Button x:Name="SaveBtn" Content="Сохранить" Style="{StaticResource PrimaryButton}"
                            Click="SaveBtn_Click" Width="140"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
