<Window x:Class="ConstructionMaterialsManager.Views.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" WindowStartupLocation="CenterScreen"
        Height="550" Width="440" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Background="{StaticResource SurfaceBrush}"
                CornerRadius="16" Margin="24"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="Black"/>
            </Border.Effect>

            <StackPanel Margin="40,48">
                <TextBlock Text="🏗️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="СтройМатериалы" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Войдите в систему для продолжения" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <TextBlock Text="Логин" Style="{StaticResource FormTextBlock}" Margin="0,0,0,6"/>
                <TextBox x:Name="LoginTextBox" Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,20" Height="44"/>

                <TextBlock Text="Пароль" Style="{StaticResource FormTextBlock}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,8" Height="44"/>

                <TextBlock x:Name="ErrorTextBlock" Foreground="{StaticResource DangerBrush}"
                           FontSize="12" TextAlignment="Center" Margin="0,0,0,16"
                           Visibility="Collapsed"/>

                <Button x:Name="LoginButton" Content="Войти" Style="{StaticResource PrimaryButton}"
                        Click="LoginButton_Click" Height="48" FontSize="14"/>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>
