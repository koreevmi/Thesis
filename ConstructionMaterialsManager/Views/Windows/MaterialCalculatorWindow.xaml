<Window x:Class="ConstructionMaterialsManager.Views.Windows.MaterialCalculatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор расхода материалов" WindowStartupLocation="CenterScreen"
        Height="700" Width="820" ResizeMode="CanResize" MinHeight="620" MinWidth="780"
        Background="{StaticResource BackgroundBrush}">

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="16" Margin="16"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="🧮" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Калькулятор расхода материалов" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Расчет потребности и сравнение План/Факт" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Табы -->
            <TabControl Grid.Row="1" x:Name="MainTabControl" Margin="0,0,0,16"
                        Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="FontWeight" Value="Medium"/>
                        <Setter Property="Padding" Value="16,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Border" Background="{TemplateBinding Background}"
                                            CornerRadius="8,8,0,0" Padding="{TemplateBinding Padding}"
                                            Margin="0,0,4,0">
                                        <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Вкладка: Расчет по параметрам дороги -->
                <TabItem Header="Расчет по параметрам">
                    <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Левая часть: ввод параметров -->
                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="Параметры участка дороги" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                                <TextBlock Text="Материал" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="MaterialComboBox" Style="{StaticResource ModernComboBox}"
                                          DisplayMemberPath="Name" Margin="0,0,0,12" Height="40"/>

                                <TextBlock Text="Длина участка (м)" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                                <TextBox x:Name="LengthTextBox" Style="{StaticResource ModernTextBox}"
                                         Height="40" Margin="0,0,0,12"/>

                                <TextBlock Text="Ширина участка (м)" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                                <TextBox x:Name="WidthTextBox" Style="{StaticResource ModernTextBox}"
                                         Height="40" Margin="0,0,0,12"/>

                                <TextBlock Text="Толщина слоя (м)" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                                <TextBox x:Name="ThicknessTextBox" Style="{StaticResource ModernTextBox}"
                                         Height="40" Margin="0,0,0,12"/>

                                <TextBlock Text="Потери (%)" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                                <TextBox x:Name="LossTextBox" Style="{StaticResource ModernTextBox}"
                                         Height="40" Text="5" Margin="0,0,0,20"/>

                                <Button x:Name="CalculateBtn" Content="Рассчитать"
                                        Style="{StaticResource PrimaryButton}" Height="44"
                                        Click="CalculateBtn_Click"/>
                            </StackPanel>

                            <!-- Правая часть: результаты -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Результат расчета" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                                <Border Background="#F8FAFC" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Объем материала" FontSize="12" FontWeight="Medium"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="VolumeResult" Text="—" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#F8FAFC" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Масса (с учетом плотности)" FontSize="12" FontWeight="Medium"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="MassResult" Text="—" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#F8FAFC" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Плановое количество (с потерями)" FontSize="12" FontWeight="Medium"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="PlannedResult" Text="—" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#DBEAFE" CornerRadius="10" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Оценочная стоимость" FontSize="12" FontWeight="Medium"
                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBlock x:Name="CostResult" Text="—" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- Вкладка: План vs Факт -->
                <TabItem Header="План / Факт">
                    <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="Проект:" VerticalAlignment="Center" Margin="0,0,8,0"
                                           FontWeight="SemiBold"/>
                                <ComboBox x:Name="ProjectComboBox" Style="{StaticResource ModernComboBox}"
                                          DisplayMemberPath="Name" SelectedValuePath="ProjectId"
                                          Width="300" SelectionChanged="ProjectComboBox_SelectionChanged"/>
                                <Button x:Name="RefreshPlanFactBtn" Content="Обновить"
                                        Style="{StaticResource SecondaryButton}" Margin="12,0,0,0"
                                        Click="RefreshPlanFactBtn_Click"/>
                            </StackPanel>

                            <DataGrid Grid.Row="1" x:Name="PlanFactDataGrid" Style="{StaticResource ModernDataGrid}"
                                      AutoGenerateColumns="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Материал" Binding="{Binding Material.Name}" Width="2*"/>
                                    <DataGridTextColumn Header="Тип" Binding="{Binding Material.MaterialType.Name}" Width="*"/>
                                    <DataGridTextColumn Header="План" Binding="{Binding PlannedQuantity, StringFormat={}{0:N2}}" Width="*"/>
                                    <DataGridTextColumn Header="Факт" Binding="{Binding ActualUsed, StringFormat={}{0:N2}}" Width="*"/>
                                    <DataGridTextColumn Header="Перерасход" Binding="{Binding Overrun, StringFormat={}{0:N2}}" Width="*"/>
                                    <DataGridTemplateColumn Header="%" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="6" Padding="8,4"
                                                        Background="{Binding OverrunPercent, Converter={StaticResource OverrunToColorConverter}}">
                                                    <TextBlock Text="{Binding OverrunPercent, StringFormat={}{0:N1}%}"
                                                               FontWeight="SemiBold" FontSize="12"
                                                               Foreground="White" TextAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Стоимость" Binding="{Binding EstimatedCost, StringFormat={}{0:N2} ₽}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- Кнопки -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CloseBtn" Content="Закрыть"
                        Style="{StaticResource SecondaryButton}"
                        Click="CloseBtn_Click" Width="140"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
