<Window x:Class="ConstructionMaterialsManager.Views.Windows.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь" WindowStartupLocation="CenterScreen"
        Height="520" Width="520" ResizeMode="CanResize" MinHeight="480" MinWidth="480"
        Background="{StaticResource BackgroundBrush}">

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="16" Margin="20"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Пользователь"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Логин" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="LoginTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Пароль" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="ФИО" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="FullNameTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Email" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="EmailTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Height="40"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Роль" Style="{StaticResource FormTextBlock}" Margin="0,0,0,4"/>
                <ComboBox Grid.Row="5" Grid.Column="1" x:Name="RoleComboBox" Style="{StaticResource ModernComboBox}" Margin="0,0,0,24" Height="40">
                    <ComboBoxItem Content="Администратор"/>
                    <ComboBoxItem Content="Инженер"/>
                    <ComboBoxItem Content="Гость"/>
                </ComboBox>

                <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelBtn" Content="Отмена" Style="{StaticResource SecondaryButton}"
                            Click="CancelBtn_Click" Width="120" Margin="0,0,12,0"/>
                    <Button x:Name="SaveBtn" Content="Сохранить" Style="{StaticResource PrimaryButton}"
                            Click="SaveBtn_Click" Width="140"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
