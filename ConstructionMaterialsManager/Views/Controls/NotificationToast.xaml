<UserControl x:Class="ConstructionMaterialsManager.Views.Controls.NotificationToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="380" Height="Auto" MaxHeight="120">
    <Border x:Name="ToastBorder" CornerRadius="10" Padding="16" Margin="0,0,0,8"
            BorderThickness="1" BorderBrush="#E2E8F0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Иконка -->
            <TextBlock x:Name="IconText" Grid.Column="0" FontSize="24" VerticalAlignment="Top"
                       Margin="0,0,12,0"/>

            <!-- Текст -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontSize="13" FontWeight="SemiBold"
                           Foreground="#0F172A" TextWrapping="Wrap" MaxHeight="36"/>
                <TextBlock x:Name="MessageText" FontSize="12" Foreground="#64748B"
                           TextWrapping="Wrap" MaxHeight="48" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Кнопка закрытия -->
            <Button Grid.Column="2" Content="✕" FontSize="12" Background="Transparent"
                    BorderThickness="0" Foreground="#94A3B8" Cursor="Hand"
                    Click="CloseButton_Click" Padding="4" VerticalAlignment="Top"/>
        </Grid>
    </Border>
</UserControl>
