<UserControl x:Class="ConstructionMaterialsManager.Views.Pages.UsersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
                <TextBlock Text="👥" FontSize="32" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Пользователи" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Управление пользователями системы" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Панель действий -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="AddBtn" Content="＋ Добавить"
                            Style="{StaticResource PrimaryButton}"
                            Click="AddBtn_Click" Margin="0,0,8,0"/>
                    <Button x:Name="EditBtn" Content="✎ Изменить"
                            Style="{StaticResource SecondaryButton}"
                            Click="EditBtn_Click" Margin="0,0,8,0"/>
                    <Button x:Name="DeleteBtn" Content="✕ Удалить"
                            Style="{StaticResource DangerButton}"
                            Click="DeleteBtn_Click"/>
                </StackPanel>
            </Border>

            <!-- Таблица -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
                <DataGrid x:Name="DataGrid" Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernDataGridColumnHeader}"/>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}"/>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCell}"/>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="*"/>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
