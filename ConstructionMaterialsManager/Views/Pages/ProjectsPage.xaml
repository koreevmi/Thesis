<UserControl x:Class="ConstructionMaterialsManager.Views.Pages.ProjectsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
                <TextBlock Text="📋" FontSize="32" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Проекты" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Управление строительными проектами" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Панель действий и фильтров -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Кнопки действий -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="AddProjectBtn" Content="＋ Добавить"
                                Style="{StaticResource PrimaryButton}"
                                Click="AddProjectBtn_Click" Margin="0,0,8,0"/>
                        <Button x:Name="EditProjectBtn" Content="✎ Изменить"
                                Style="{StaticResource SecondaryButton}"
                                Click="EditProjectBtn_Click" Margin="0,0,8,0"/>
                        <Button x:Name="DeleteProjectBtn" Content="✕ Удалить"
                                Style="{StaticResource DangerButton}"
                                Click="DeleteProjectBtn_Click" Margin="0,0,8,0"/>
                        <Button x:Name="ViewMaterialsBtn" Content="📦 Материалы"
                                Style="{StaticResource SuccessButton}"
                                Click="ViewMaterialsBtn_Click"/>
                    </StackPanel>

                    <!-- Фильтры -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="260" Margin="0,0,12,0">
                            <TextBox x:Name="ProjectFilterTextBox" Style="{StaticResource SearchBox}"
                                     TextChanged="ProjectFilterTextBox_TextChanged"/>
                            <TextBlock x:Name="ProjectFilterWatermark" Text="🔍  Поиск по названию..."
                                       Style="{StaticResource WatermarkText}"/>
                        </Grid>
                        <ComboBox x:Name="ProjectStatusFilter" Width="170" Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="ProjectStatusFilter_SelectionChanged">
                            <ComboBoxItem Content="Все статусы" Tag="" IsSelected="True"/>
                            <ComboBoxItem Content="Запланирован" Tag="Запланирован"/>
                            <ComboBoxItem Content="В процессе" Tag="В процессе"/>
                            <ComboBoxItem Content="Завершен" Tag="Завершен"/>
                            <ComboBoxItem Content="Отменен" Tag="Отменен"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Таблица -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
                <DataGrid x:Name="ProjectsDataGrid" Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernDataGridColumnHeader}"/>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}"/>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCell}"/>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*"/>
                        <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                        <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                        <DataGridTextColumn Header="Бюджет" Binding="{Binding Budget, StringFormat={}{0:N2} ₽}" Width="Auto"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
