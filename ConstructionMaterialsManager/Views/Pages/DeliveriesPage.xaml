<UserControl x:Class="ConstructionMaterialsManager.Views.Pages.DeliveriesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
                <TextBlock Text="🚚" FontSize="32" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Поставки" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Учёт поставок материалов" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Панель действий и фильтров -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Кнопки действий -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="AddDeliveryBtn" Content="＋ Добавить"
                                Style="{StaticResource PrimaryButton}"
                                Click="AddDeliveryBtn_Click" Margin="0,0,8,0"/>
                        <Button x:Name="EditDeliveryBtn" Content="✎ Изменить"
                                Style="{StaticResource SecondaryButton}"
                                Click="EditDeliveryBtn_Click" Margin="0,0,8,0"/>
                        <Button x:Name="DeleteDeliveryBtn" Content="✕ Удалить"
                                Style="{StaticResource DangerButton}"
                                Click="DeleteDeliveryBtn_Click"/>
                    </StackPanel>

                    <!-- Фильтры -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="180" Margin="0,0,8,0">
                            <TextBox x:Name="DeliveryFilterTextBox" Style="{StaticResource SearchBox}"
                                     TextChanged="DeliveryFilterTextBox_TextChanged"/>
                            <TextBlock x:Name="DeliveryFilterWatermark" Text="🔍  Материал..."
                                       Style="{StaticResource WatermarkText}"/>
                        </Grid>
                        
                        <ComboBox x:Name="SupplierFilter" Width="130" Style="{StaticResource ModernComboBox}"
                                  DisplayMemberPath="Name" SelectedValuePath="SupplierId"
                                  SelectionChanged="SupplierFilter_SelectionChanged" Margin="0,0,8,0"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="С:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <DatePicker x:Name="StartDatePicker" Style="{StaticResource ModernDatePicker}"
                                        Width="100" Margin="0,0,8,0"
                                        SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                            <TextBlock Text="По:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <DatePicker x:Name="EndDatePicker" Style="{StaticResource ModernDatePicker}"
                                        Width="100"
                                        SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Таблица -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
                <DataGrid x:Name="DeliveriesDataGrid" Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernDataGridColumnHeader}"/>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}"/>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCell}"/>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Материал" Binding="{Binding Material.Name}" Width="*"/>
                        <DataGridTextColumn Header="Партия" Binding="{Binding BatchNumber}" Width="Auto"/>
                        <DataGridTextColumn Header="Сертификат" Binding="{Binding CertificateNumber}" Width="Auto"/>
                        <DataGridTextColumn Header="Количество" Binding="{Binding Quantity, StringFormat={}{0:N2}}" Width="Auto"/>
                        <DataGridTextColumn Header="Дата поставки" Binding="{Binding DeliveryDate, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                        <DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier.Name}" Width="*"/>
                        <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
