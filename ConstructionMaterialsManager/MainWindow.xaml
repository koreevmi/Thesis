<Window x:Class="ConstructionMaterialsManager.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет строительных материалов" WindowStartupLocation="CenterScreen"
        Height="740" Width="1500"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== SIDEBAR ========== -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                CornerRadius="0" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Логотип / Заголовок -->
                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="20,0">
                    <TextBlock Text="🏗️" FontSize="28" VerticalAlignment="Center"/>
                    <TextBlock Text="СтройМатериалы" FontSize="16" FontWeight="Bold"
                               Foreground="White" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Разделитель -->
                <Border Grid.Row="1" Height="1" Background="#334155" Margin="16,0"/>

                <!-- Навигация -->
                <StackPanel Grid.Row="2" Margin="12,16,12,0">
                    <TextBlock Text="НАВИГАЦИЯ" FontSize="11" FontWeight="Bold"
                               Foreground="#64748B" Margin="8,0,0,12"/>
                    
                    <RadioButton x:Name="MaterialsNavBtn" Style="{StaticResource SidebarMenuItem}"
                                 Content="Материалы" Tag="📦"
                                 Checked="MaterialsNavBtn_Checked"/>
                    <RadioButton x:Name="ProjectsNavBtn" Style="{StaticResource SidebarMenuItem}"
                                 Content="Проекты" Tag="📋"
                                 Checked="ProjectsNavBtn_Checked"/>
                    <RadioButton x:Name="SuppliersNavBtn" Style="{StaticResource SidebarMenuItem}"
                                 Content="Поставщики" Tag="🤝"
                                 Checked="SuppliersNavBtn_Checked"/>
                    <RadioButton x:Name="DeliveriesNavBtn" Style="{StaticResource SidebarMenuItem}"
                                 Content="Поставки" Tag="🚚"
                                 Checked="DeliveriesNavBtn_Checked"/>
                    <RadioButton x:Name="QualityChecksNavBtn" Style="{StaticResource SidebarMenuItem}"
                                 Content="Контроль качества" Tag="🔬"
                                 Checked="QualityChecksNavBtn_Checked"/>
                    <RadioButton x:Name="ReportsNavBtn" Style="{StaticResource SidebarMenuItem}"
                                 Content="Отчёты" Tag="📊"
                                 Checked="ReportsNavBtn_Checked"/>
                    <RadioButton x:Name="NotificationsNavBtn" Style="{StaticResource SidebarMenuItem}"
                                 Content="Уведомления" Tag="🔔"
                                 Checked="NotificationsNavBtn_Checked"/>
                    <RadioButton x:Name="UsersNavBtn" Style="{StaticResource SidebarMenuItem}"
                                 Content="Пользователи" Tag="👥"
                                 Checked="UsersNavBtn_Checked" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Пользователь / Выход -->
                <Border Grid.Row="3" Background="#0F172A" Margin="12,0,12,12" CornerRadius="10" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="UserNameLabel" Text="Пользователь" FontSize="13"
                                   FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock x:Name="UserRoleLabel" Text="Роль" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,2,0,12"/>
                        <!-- Уведомления -->
                        <Border x:Name="NotificationBadge" Background="#EF4444" CornerRadius="10"
                                Padding="8,6" Margin="0,0,0,12" Cursor="Hand"
                                MouseLeftButtonDown="NotificationBadge_Click" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔔" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock x:Name="UnreadCountLabel" Text="0" FontSize="12" FontWeight="Bold"
                                           Foreground="White" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Text="новых" FontSize="11" Foreground="#FECACA"
                                           Margin="4,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Button x:Name="LogoutButton" Content="← Выйти"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Stretch"
                                Click="LogoutButton_Click"
                                Foreground="#CBD5E1" BorderBrush="#334155"
                                Padding="8,6" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ========== ОСНОВНОЙ КОНТЕНТ ========== -->
        <Grid Grid.Column="1" Margin="24">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
            <!-- Контейнер для toast-уведомлений -->
            <StackPanel x:Name="ToastContainer" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,16,16,0" Panel.ZIndex="999"/>
        </Grid>
    </Grid>
</Window>
